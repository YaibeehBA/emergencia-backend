# Configuración de la API
ENVIRONMENT=development
DEBUG=True
# development - entorno de desarrollo local
# staging - entorno de pruebas pre-producción
# production - entorno de producción

# Configuración de la Base de Datos
DATABASE_URL=sqlite:///./emergencia.db
# Para PostgreSQL en producción: postgresql://usuario:password@localhost:5432/emergencia_db

# Agentes IA - Múltiples Proveedores
ACTIVE_AGENT=groq
# Opciones: groq (recomendado, rápido y gratuito) o gemini

# Configuración de Google Gemini
GEMINI_API_KEY=AIzxxxxaSxxxxBxxxxhLgx0gdxxx
AGENT_MODEL=gemini-2.5-flash

# Configuración de Groq
GROQ_API_KEY=gsk_tu_api_key_aqui
GROQ_MODEL=llama-3.3-70b-versatile

# Configuración común del Agente
AGENT_TEMPERATURE=0.7
# Temperatura: 0 = más preciso, 1 = más creativo
AGENT_MAX_TOKENS=1000
# Máximo de tokens en la respuesta del agente

# Configuración de Correo Electrónico
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucuenta@gmail.com
SMTP_PASSWORD=tu_contraseña_app
SENDER_EMAIL=noreply@emergencia-sync.com
SENDER_NAME=Emergencia-Sync

# Modo de prueba de correo
MOCK_EMAIL=False
# True: no envía correos reales (solo logs)
# False: envía correos reales

# Configuración de Seguridad
SECRET_KEY=tu-llave-secreta-cambiar-en-produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Configuración de Logs
LOG_LEVEL=INFO
# Niveles: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/app.log

# Configuración del Webhook
WEBHOOK_SECRET=webhook-secret
WEBHOOK_TIMEOUT_SECONDS=30
